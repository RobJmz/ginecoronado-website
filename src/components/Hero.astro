---
---
<section class="hero-gradient min-h-[80vh] flex flex-col overflow-hidden">
  <!-- Top bar: social left, CTA button right -->
  <div class="flex items-center justify-between px-6 md:px-8 py-5 md:py-6">
    <div class="flex items-center gap-6 md:gap-8">
      <a
        href="https://www.instagram.com/dr.ricardo_coronado/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#4F4F4F] hover:text-verde-vela transition-colors text-sm md:text-base font-sans font-bold"
        aria-label="Instagram"
      >
        Instagram
      </a>
      <a
        href="https://www.facebook.com/Dr.RicardoCoronado"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#4F4F4F] hover:text-verde-vela transition-colors text-sm md:text-base font-sans font-bold"
        aria-label="Facebook"
      >
        Facebook
      </a>
    </div>
    <a
      href="https://wa.me/528441850060?text=Hola, me interesa agendar una cita."
      target="_blank"
      rel="noopener noreferrer"
      class="bg-verde-vela hover:bg-[#38474B] text-white font-sans font-bold text-xs md:text-sm tracking-[0.1em] uppercase px-4 py-2.5 md:px-5 md:py-3 rounded-lg transition-colors"
    >
      Agenda tu cita
    </a>
  </div>

  <!-- Centered content: logo, DOCTOR, name, specialties, tagline -->
  <div class="flex-1 flex flex-col items-center justify-center text-center px-6 pb-12 md:pb-16">
    <!-- Logo: 50% width of container -->
    <div class="mb-8 md:mb-10 w-full flex justify-center">
      <img
        src="/images/logo-oscuro.png"
        alt="Doctor Ricardo Coronado - Ginecología, Obstetricia, Colposcopía"
        width="400"
        height="400"
        class="w-1/2 min-w-[200px] max-w-md object-contain"
        loading="eager"
      />
    </div>
    <p class="text-verde-vela font-sans font-bold text-[1.25rem] md:text-[1.4rem] lg:text-[1.56rem] leading-relaxed max-w-xl text-balance">
      Escucha, calidad y atenci&oacute;n<br class="hidden sm:inline" />
      en un ambiente seguro y de confianza.
    </p>
  </div>
</section>
