---
const serviceItems = [
  'Primera Visita',
  'Anticonceptivos',
  'Colposcopía',
  'Control prenatal',
  'Maternidad',
  'Atención posparto',
  'Cirugía Ginecológica',
  'Detección oportuna de cáncer en la mujer',
]
---

<section id="servicios-ubicacion" class="grid grid-cols-1 lg:grid-cols-2 min-h-0">
  <!-- Left: Servicios (light green) -->
  <div class="services-location-left bg-verde-turquesa/25 py-12 md:py-16 lg:py-20 px-6 md:px-10 lg:px-14 flex flex-col justify-start text-center">
    <h2 class="font-sans font-bold text-2xl md:text-3xl lg:text-4xl text-verde-vela mb-8 lg:mb-10">
      Servicios
    </h2>
    <ul class="space-y-4 font-sans font-bold text-verde-vela text-base md:text-lg leading-relaxed w-full list-none pl-0">
      {serviceItems.map((item) => (
        <li key={item}>{item}</li>
      ))}
    </ul>
  </div>

  <!-- Right: Visítanos (light purple) -->
  <div class="services-location-right bg-lila-claro py-12 md:py-16 lg:py-20 px-6 md:px-10 lg:px-14 flex flex-col text-center">
    <h2 class="font-sans font-bold text-2xl md:text-3xl lg:text-4xl text-verde-vela mb-6 lg:mb-8 text-balance">
      Vis&iacute;tanos en una de las zonas m&aacute;s importantes de Saltillo
    </h2>
    <div class="rounded-xl overflow-hidden mb-6 lg:mb-8 flex-shrink-0">
      <iframe
        title="Ubicación del consultorio del Dr. Ricardo Coronado en Centro Médico Muguerza, Saltillo"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3601.8396648071707!2d-100.98263871521984!3d25.477028762393278!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8688136293bfef59%3A0x197b3401897792fd!2sDr.%20Ricardo%20Coronado!5e0!3m2!1ses!2smx!4v1772504345325!5m2!1ses!2smx"
        width="100%"
        height="450"
        style="border: 0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full h-64 md:h-80 lg:h-[450px]"
      />
    </div>
    <address class="font-sans font-bold text-verde-vela text-base md:text-lg leading-relaxed not-italic text-center">
      Centro M&eacute;dico Muguerza Piso 1<br />
      Consultorio 101 Paseo Villalta.<br />
      Luis Donaldo Colosio esquina con V. Carranza<br />
      Col. Rancho de Pe&ntilde;a 25210 Saltillo, Coah.
    </address>
  </div>
</section>
