---
import '../../app/globals.css'

const title =
  'Dr. Ricardo Coronado | Ginecología, Obstetricia y Colposcopía en Saltillo'
const description =
  'Especialista en ginecología, obstetricia y colposcopía. Escucha, calidad y atención en un ambiente seguro y de confianza. Centro Médico Muguerza, Saltillo, Coah.'
const keywords = [
  'ginecólogo',
  'obstetricia',
  'colposcopía',
  'control prenatal',
  'embarazo de alto riesgo',
  'colposcopía en Saltillo',
  'ginecólogo en Saltillo',
  'Dr. Ricardo Coronado',
  'Centro Médico Muguerza Saltillo',
].join(', ')

// TODO: Reemplaza esta URL con el dominio real de la landing
const siteUrl = 'https://example.com'
const ogImage = '/images/foto.png'

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: 'Dr. Ricardo Coronado',
  url: siteUrl,
  image: siteUrl + ogImage,
  telephone: '+52-844-185-0060',
  medicalSpecialty: ['Gynecology', 'Obstetrics', 'Colposcopy'],
  address: {
    '@type': 'PostalAddress',
    streetAddress:
      'Paseo Villalta, Luis Donaldo Colosio esquina con V. Carranza, Col. Rancho de Peña',
    addressLocality: 'Saltillo',
    addressRegion: 'Coahuila',
    postalCode: '25210',
    addressCountry: 'MX',
  },
  sameAs: [
    'https://www.instagram.com/dr.ricardo_coronado/',
    'https://www.facebook.com/Dr.RicardoCoronado',
  ],
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#253534" />

    <link rel="canonical" href={siteUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="alternate icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Google Fonts: DM Sans & DM Serif Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..144,100..1000;1,9..144,100..1000&family=DM+Serif+Display&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={siteUrl + ogImage} />
    <meta property="og:site_name" content="Dr. Ricardo Coronado" />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteUrl + ogImage} />

    <script type="application/ld+json" is:inline>
      {JSON.stringify(businessSchema)}
    </script>
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>

